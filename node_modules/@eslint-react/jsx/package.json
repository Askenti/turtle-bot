    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@typescript-eslint/types": "^8.59.4",
    "@typescript-eslint/utils": "^8.59.4",
    "ts-pattern": "^5.9.0",
    "@eslint-react/ast": "5.8.4",
    "@eslint-react/var": "5.8.4",
    "@eslint-react/eslint": "5.8.4",
    "@eslint-react/shared": "5.8.4"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "@local/configs": "0.0.0",
    "@local/eff": "3.0.0-beta.72"
  },
  "peerDependencies": {
    "eslint": "^10.3.0",
    "typescript": "*"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "inlinedDependencies": {
    "@local/eff": "workspace:*"
  },
  "scripts": {
    "build": "tsdown",
    "build:docs": "typedoc",
    "lint:publish": "publint",
    "lint:ts": "tsl"
  }
